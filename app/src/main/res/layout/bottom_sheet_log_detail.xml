<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1a1a1a"
    android:padding="20dp"
    android:maxHeight="600dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Лог подключения"
        android:textColor="#607D8B"
        android:textStyle="bold"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginBottom="15dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">
        <TextView
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="🕐 Время:"
            android:textColor="#888888"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/bottomLogTime"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="16.03.2026 08:37:15"
            android:textColor="#FFC107"
            android:textStyle="bold"
            android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">
        <TextView
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="📍 Сетевой адрес:"
            android:textColor="#888888"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/bottomLogAddr"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="081"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">
        <TextView
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="🔢 Серийник:"
            android:textColor="#888888"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/bottomLogSerial"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="48253981"
            android:textColor="#607D8B"
            android:textStyle="bold"
            android:textSize="13sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="15dp">
        <TextView
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="✅ Статус:"
            android:textColor="#888888"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/bottomLogStatus"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Успешно"
            android:textColor="#66BB6A"
            android:textStyle="bold"
            android:textSize="13sp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="15dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📝 Журнал обмена:"
        android:textColor="#888888"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#000000"
        android:padding="10dp"
        android:layout_marginBottom="15dp">

        <TextView
            android:id="@+id/bottomLogMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Чтение показаний...\n✅ TCP соединение установлено\n..."
            android:textColor="#00ff00"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:lineSpacingExtra="3dp"/>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/bottomLogCopy"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="📋 Копировать"
            android:backgroundTint="#607D8B"
            android:layout_marginEnd="5dp"
            android:minHeight="48dp"/>

        <Button
            android:id="@+id/bottomLogClose"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="✕ Закрыть"
            android:backgroundTint="#4CAF50"
            android:layout_marginStart="5dp"
            android:minHeight="48dp"/>
    </LinearLayout>
</LinearLayout>